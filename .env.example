APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Geolocalización (OPCIONAL)
# - GEOCODING_ENABLED: true/false para habilitar reverse geocoding (ciudad, país, dirección)
# - GEOCODING_PROVIDER: none|nominatim|geoapify
#   * none: deshabilitado, ingesta mantiene lat/lng pero sin ciudad/país
#   * nominatim: OpenStreetMap (gratis, rate-limited a ~1 req/s)
#   * geoapify: API comercial de pago (mejor SLA y uptime)
# - GEOAPIFY_API_KEY: solo si usas geoapify (https://www.geoapify.com)
# 
# NOTA: Si GEOCODING_ENABLED=false, los tokens/devices/registros funcionan igual.
#       El reverse geocoding es enriquecimiento opcional que falla gracefully.
GEOCODING_ENABLED=false
GEOCODING_PROVIDER=none
GEOCODING_TIMEOUT_SECONDS=2
GEOAPIFY_API_KEY=


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Producción (Hostinger SMTP sugerido)
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=587
# MAIL_USERNAME=alerts@tu-dominio.com
# MAIL_PASSWORD=tu_password_smtp
# MAIL_FROM_ADDRESS="alerts@tu-dominio.com"
# MAIL_FROM_NAME="${APP_NAME} Alerts"

# Alertas (Commit 3)
ALERT_OFFLINE_AFTER_MINUTES=3
ALERT_RENOTIFY_COOLDOWN_MINUTES=30
ALERT_MAIL_MIN_SEVERITY=alta
ALERT_PUSH_MIN_SEVERITY=critica

# Alertas de pH (Commit de la semana 4)
ALERT_PH_SAFE_MIN=6.5
ALERT_PH_SAFE_MAX=8.0
ALERT_PH_CRITICAL_MIN=6.0
ALERT_PH_CRITICAL_MAX=8.5
#opcionales solo para alertas de pH, si no se configuran se ignoran y no se generan alertas de pH
#recordar priorirzar el archivo de configuración por entorno (.env) para estas variables, ya que pueden variar según el tipo de agua (dulce, salada, etc.) y las especies acuáticas presentes.

# Web Push (Commit 6)
# Genera estas claves una vez por entorno y reutilízalas.
# Si rotas las keys, las suscripciones push existentes deberán renovarse.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@example.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
